{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": null,
  "outputDirectory": "dist/server",
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs@22"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}
